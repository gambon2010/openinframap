# Copy this file to .env and adjust to your local setup.
#
# The 'osm' user and database are created automatically by the Docker Compose
# 'db' service (via schema/dev-init.sql). Run scripts/setup-local-db.sh first.
DATABASE_URL=postgresql://osm:osm@localhost:5432/osm

# Enable debug mode: disables HTTP cache headers so every response is fresh.
# DEBUG=true
