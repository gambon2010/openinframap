# Tile server base URL. Defaults to the production server so the app works
# out of the box for new contributors. Used for basemap and black-marble
# raster tiles, which are not served by local Tegola.
VITE_TILE_BASE_URL=https://openinframap.org

# Local Tegola URL. When set, OIM infrastructure tile requests (power,
# petroleum, telecoms, water, etc.) are proxied through the Vite dev server
# to this address. Tegola serves at /maps/* and the proxy rewrites
# /map/* → /maps/* automatically. Requires: docker compose up tegola
# VITE_TEGOLA_URL=http://localhost:8080

# Web-backend base URL. Defaults to the production server.
# Override this to point at a local `uv run uvicorn main:app --reload`
# instance (see web-backend/).
VITE_BACKEND_BASE_URL=https://openinframap.org
